---
import { themes, defaultThemeId, storageKey } from '../lib/themes';

const themeIds = themes.map(t => t.id);
const themeLabels = Object.fromEntries(themes.map(t => [t.id, t.name]));
---

<details class="theme-menu" data-theme-menu>
  <summary
    class="theme-toggle"
    data-themes={JSON.stringify(themeIds)}
    data-labels={JSON.stringify(themeLabels)}
    data-default={defaultThemeId}
    data-storage-key={storageKey}
    aria-label="Switch theme"
  >
    <svg class="theme-toggle__icon" width="14" height="14" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2"
         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="13.5" cy="6.5" r=".5" fill="currentColor" />
      <circle cx="17.5" cy="10.5" r=".5" fill="currentColor" />
      <circle cx="8.5" cy="7.5" r=".5" fill="currentColor" />
      <circle cx="6.5" cy="12.5" r=".5" fill="currentColor" />
      <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z" />
    </svg>
    <span class="theme-toggle__label" data-theme-label></span>
    <svg class="theme-toggle__chevron" width="10" height="10" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2.5"
         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="6 9 12 15 18 9" />
    </svg>
  </summary>

  <div class="theme-dropdown" role="menu">
    {themes.map(t => (
      <button
        type="button"
        class="theme-option"
        role="menuitem"
        data-theme-option={t.id}
      >
        <span class="theme-option__check" aria-hidden="true">✓</span>
        {t.name}
      </button>
    ))}
  </div>
</details>

<script>
  const menu = document.querySelector<HTMLDetailsElement>('[data-theme-menu]');
  if (menu) {
    const summary = menu.querySelector<HTMLElement>('[data-themes]')!;
    const themes: string[] = JSON.parse(summary.dataset.themes ?? '[]');
    const labels: Record<string, string> = JSON.parse(summary.dataset.labels ?? '{}');
    const fallback = summary.dataset.default ?? themes[0];
    const key = summary.dataset.storageKey ?? 'atc-theme';
    const labelEl = summary.querySelector<HTMLElement>('[data-theme-label]');

    const currentTheme = () => document.documentElement.dataset.theme || fallback;

    const sync = () => {
      const current = currentTheme();
      if (labelEl) labelEl.textContent = labels[current] ?? current;
      summary.setAttribute('aria-label', `Theme: ${labels[current] ?? current}`);
      menu.querySelectorAll<HTMLElement>('[data-theme-option]').forEach(btn => {
        btn.dataset.active = btn.dataset.themeOption === current ? 'true' : 'false';
      });
    };
    sync();

    menu.querySelectorAll<HTMLButtonElement>('[data-theme-option]').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        const next = btn.dataset.themeOption!;
        if (next === fallback) {
          document.documentElement.removeAttribute('data-theme');
        } else {
          document.documentElement.dataset.theme = next;
        }
        try { localStorage.setItem(key, next); } catch { /* ignore */ }
        sync();
        menu.open = false;
      });
    });

    // Close on outside click
    document.addEventListener('mousedown', e => {
      if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
    });
  }
</script>

<style>
  .theme-menu {
    position: relative;
  }

  .theme-menu summary {
    list-style: none;
  }
  .theme-menu summary::-webkit-details-marker {
    display: none;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    height: 28px;
    padding: 0 var(--space-sm);
    background: transparent;
    color: var(--header-fg-muted);
    border: 1px solid var(--header-border);
    border-radius: var(--radius-pill);
    font-family: inherit;
    font-size: var(--text-xs);
    font-weight: 500;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
    user-select: none;
  }

  .theme-toggle:hover,
  .theme-menu[open] .theme-toggle {
    color: var(--header-fg);
    background: var(--header-link-hover-bg);
    border-color: color-mix(in oklch, var(--header-fg) 30%, transparent);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 2px;
  }

  .theme-toggle__icon {
    flex-shrink: 0;
  }

  .theme-toggle__chevron {
    flex-shrink: 0;
    opacity: 0.6;
    transition: transform 0.15s ease;
  }
  .theme-menu[open] .theme-toggle__chevron {
    transform: rotate(180deg);
  }

  .theme-dropdown {
    position: absolute;
    top: calc(100% + var(--space-xs));
    right: 0;
    z-index: var(--z-popover);
    min-width: 140px;
    padding: 4px;
    background: var(--card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    box-shadow: var(--elevation-high);
  }

  .theme-option {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    width: 100%;
    padding: var(--space-sm) var(--space-md);
    border: 0;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--foreground);
    font: inherit;
    font-size: var(--text-sm);
    text-align: left;
    cursor: pointer;
    transition: background 0.1s ease;
  }
  .theme-option:hover {
    background: var(--primary-muted);
  }
  .theme-option[data-active="true"] {
    color: var(--primary);
    font-weight: 600;
  }

  .theme-option__check {
    width: 12px;
    font-size: var(--text-xs);
    color: var(--primary);
    visibility: hidden;
  }
  .theme-option[data-active="true"] .theme-option__check {
    visibility: visible;
  }

  @media (max-width: 480px) {
    .theme-toggle__label {
      display: none;
    }
  }
</style>
